{
    "extends": "@tsconfig/node24/tsconfig.json",
    "include": [
        "vite.config.*",
        "vitest.config.*",
        "playwright.config.*",
        "eslint.config.*",
        "prettier.config.ts",
        "stylelint.config.*",
        "builder/**/*",
        "src/dts/env.d.ts"
    ],
    "compilerOptions": {
        "module": "preserve",
        "moduleResolution": "bundler",
        "verbatimModuleSyntax": true,
        "types": ["node"],
        "noEmit": true,
        "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo"
    }
}
