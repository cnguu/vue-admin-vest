{
    "name": "vue-admin-vest",
    "version": "0.0.0",
    "private": true,
    "description": "管理后台模板",
    "keywords": [
        "vue",
        "vue3",
        "admin",
        "vest",
        "monorepo",
        "vite"
    ],
    "homepage": "https://github.com/cnguu/vue-admin-vest",
    "bugs": "https://github.com/cnguu/vue-admin-vest/issues",
