        "vite": "8.0.8",
        "vite-plugin-vue-devtools": "8.1.1",
        "vitest": "4.1.4",
        "vue-tsc": "3.2.6"
    },
    "engines": {
        "node": ">=24.0.0",
        "pnpm": ">=10.0.0"
    }
